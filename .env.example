# Required: Breez SDK API key (get from https://breez.technology)
SPORKY_API_KEY=

# Required: Bot's Nostr private key (nsec or hex) — used to encrypt the wallet file with NIP-44
SPORKY_NSEC=

# Optional: Mnemonic phrase (bypasses encrypted file storage — use for headless bots)
# SPORKY_MNEMONIC=

# Optional: Network (mainnet or regtest, default: mainnet)
# SPORKY_NETWORK=mainnet

# Optional: Custom data directory (default: ~/.sporky)
# SPORKY_DATA_DIR=
